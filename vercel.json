{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "RIOT_API_KEY": "@riot_api_key"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
